# =============================================================================
# Debian Server Base - Environment Configuration Blueprint
# Copy this file to '.env' and populate with real data before generating image.
# =============================================================================

# ==========================================
# Target Hardware Environment Specs
# ==========================================
# The targeted drive where the automated OS partitioning will occur (eg /dev/sda, /dev/nvme0n1)
INSTALL_DISK="disk_name"

# The host physical Ethernet interface name (eg, enp3s0, eth0)
NET_IFACE="ethernet_name"

# Target deployment node identifiers
HOSTNAME="system_name"
TIMEZONE="system_time" # (eg America/Los_Angeles)

# ==========================================
# Sudo User
# ==========================================
# Core admin/sudo configuration profile parameters
USER_NAME="username"
USER_FULLNAME="user_full_name"

# Plaintext credential strings — processed into SHA-512 hashes inside generate_installer.py
ROOT_PASSWORD_PLAIN="root_password"
USER_PASSWORD_PLAIN="user_password"

# ==========================================
# Access Hardening
# ==========================================
# Hardened non-standard listening endpoint for the openssh service wrapper
SSH_PORT="2222" # Can be changed to any port, 22 is system default (not recomended)

# Public terminal authentication cryptographic signature string line
PUBLIC_KEY="public_key"

# ==========================================
# Network Infrastructure Topology (Static Allocation)
# ==========================================
STATIC_IP="192.168.xx.xx"
NETMASK="255.255.252.0"
GATEWAY="192.168.xx.xx"

# Space-separated list of regional nameservers (e.g. Cloudflare, Google, or local router gateway)
DNS_SERVERS="8.8.8.8 8.8.4.4"